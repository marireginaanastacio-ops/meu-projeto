# Prospect Hunter — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais

# Apify — scraping de perfis Instagram/LinkedIn
APIFY_TOKEN=your_apify_token_here

# Google Gemini — geração de mensagens com IA
GEMINI_API_KEY=your_gemini_api_key_here

# Servidor Express
PORT=3001

# Serviço — usado no prompt template como fallback
SERVICE_NAME=LearnOS
SERVICE_DESCRIPTION=Plataforma de aprendizagem acelerada que transforma profissionais em especialistas através de metodologias práticas e projetos reais.
