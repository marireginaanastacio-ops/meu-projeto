{
  "name": "prospect-hunter-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "NODE_ENV=production node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "apify-client": "^2.9.3",
    "@google/generative-ai": "^0.21.0"
  },
  "devDependencies": {
    "vitest": "^1.2.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "vitest": {
    "environment": "node",
    "testMatch": ["tests/**/*.test.js"],
    "env": {
      "NODE_ENV": "test"
    }
  }
}
